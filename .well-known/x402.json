      "price": "0.01",
      "description": "Pay-per-call access to pscale connect"
    },
    {
      "path": "/pscale shell",
      "price": "0.01",
      "description": "Pay-per-call access to pscale shell"
    },
    {
      "path": "/pscale database",
      "price": "0.01",
      "description": "Pay-per-call access to pscale database"
    },
    {
      "path": "/pscale backup",
      "price": "0.01",
      "description": "Pay-per-call access to pscale backup"
    },
    {
      "path": "/pscale region",
      "price": "0.01",
      "description": "Pay-per-call access to pscale region"
    },
    {
      "path": "/pscale auth",
      "price": "0.01",
      "description": "Pay-per-call access to pscale auth"
    }
  ]
